#!/bin/bash

# start_android - Best-in-class script for Flutter Android Emulator

ADB=~/Library/Android/sdk/platform-tools/adb
EMULATOR=~/Library/Android/sdk/emulator/emulator
AVD=antigrvity_pixel

# 1. Use Java 17 (modern standard)
if [ -f "/usr/libexec/java_home" ]; then
    export JAVA_HOME=$(/usr/libexec/java_home -v 17)
    echo "☕ Using JAVA_HOME (Java 17): $JAVA_HOME"
fi

# 2. Ensure dependencies are up to date
echo "🚀 Getting dependencies..."
flutter pub get

# 3. Ensure Android platform exists
if [ ! -d "android" ]; then
    echo "🤖 Adding Android support..."
    flutter create --org com.eugenexlab --platforms=android .
fi

# 4. Handle Emulator
echo "📱 Checking for active emulator..."
EXISTING=$($ADB devices | grep -v "List" | grep "emulator" | head -n 1 | cut -f1)

if [ -z "$EXISTING" ]; then
    echo "✨ Starting $AVD emulator..."
    $EMULATOR -avd $AVD \
        -netdelay none \
        -netspeed full \
        -dns-server 8.8.8.8,8.8.4.4,1.1.1.1 \
        -gpu host \
        -no-boot-anim &
    
    echo "⏳ Waiting for emulator to boot..."
    $ADB wait-for-device

    echo "🛠️ Finalizing boot..."
    until $ADB shell getprop sys.boot_completed | grep -m 1 "1" >/dev/null; do sleep 2; done

    echo "✅ Emulator is ready!"
else
    echo "✅ Using existing emulator: $EXISTING"
fi

# 5. Fix network (optional)
$ADB shell settings put global http_proxy :0 >/dev/null 2>&1

# 6. Detect active device
DEVICE=$($ADB devices | grep "emulator" | head -n 1 | cut -f1)

echo "🎮 Running on $DEVICE..."

# 7. Run app
flutter run -d $DEVICE