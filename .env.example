# IMPORTANT: Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control!

# AdMob Ad Unit IDs
ADMOB_BANNER_ANDROID=your-banner-ad-unit-id-android
ADMOB_BANNER_IOS=your-banner-ad-unit-id-ios

ADMOB_APP_OPEN_ANDROID=your-app-open-ad-unit-id-android
ADMOB_APP_OPEN_IOS=your-app-open-ad-unit-id-ios

ADMOB_INTERSTITIAL_ANDROID=your-interstitial-ad-unit-id-android
ADMOB_INTERSTITIAL_IOS=your-interstitial-ad-unit-id-ios

ADMOB_REWARDED_ANDROID=your-rewarded-ad-unit-id-android
ADMOB_REWARDED_IOS=your-rewarded-ad-unit-id-ios

ADMOB_NATIVE_ANDROID=your-native-ad-unit-id-android
ADMOB_NATIVE_IOS=your-native-ad-unit-id-ios

# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
